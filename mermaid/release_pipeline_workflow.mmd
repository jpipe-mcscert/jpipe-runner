flowchart TD
    %% Trigger
    A[Push Tag 'v*.*.*'] --> B[Validate Version]

    %% Validate Version Job
    subgraph Validate Version
        B1[Checkout code]
        B2[Extract Tag Name]
        B3[Validate Tag Format]
        B4[Strip 'v' Prefix -> Version]
        B5[Check version in pyproject.toml]
        B6[Check version in setup.py]
        B --> B1 --> B2 --> B3 --> B4 --> B5 --> B6
    end

    %% Test Job
    subgraph Test
        C1[Checkout code]
        C2[Set up Python 3.10]
        C3[Cache Poetry]
        C4[Install Poetry if needed]
        C5[Add Poetry to PATH]
        C6[Cache apt packages]
        C7[Install system dependencies]
        C8[Install Python dependencies # Poetry]
        C9[Run tests # pytest]
    end

    B6 --> C1
    C1 --> C2 --> C3 --> C4 --> C5 --> C6 --> C7 --> C8 --> C9

    %% Build Python Package Job
    subgraph Build Python Package
        D1[Checkout code]
        D2[Set up Python 3.10]
        D3[Cache Poetry]
        D4[Install Poetry if needed]
        D5[Add Poetry to PATH]
        D6[Cache apt packages]
        D7[Install system dependencies]
        D8[Install dependencies # Poetry]
        D9[Build distribution]
        D10[Upload distribution artifact]
    end

    C9 --> D1
    D1 --> D2 --> D3 --> D4 --> D5 --> D6 --> D7 --> D8 --> D9 --> D10

    %% Build PPA Job
    subgraph Build PPA Package
        E1[Checkout code]
        E2[Set up Python 3.10]
        E3[Cache Poetry]
        E4[Install Poetry if needed]
        E5[Add Poetry to PATH]
        E6[Cache apt packages]
        E7[Install system dependencies]
        E8[Install dependencies # Poetry]
        E9[Export requirements.txt]
        E10[Install Python packaging tools]
        E11[Set up GPG for signing]
        E12[Build Debian package]
        E13[Upload Debian artifacts]
    end

    C9 --> E1
    E1 --> E2 --> E3 --> E4 --> E5 --> E6 --> E7 --> E8 --> E9 --> E10 --> E11 --> E12 --> E13

    %% Release Job
    subgraph Release
        F1[Checkout code]
        F2[Download Python package artifacts]
        F3[Download Debian package artifacts]
        F4[Install Debian build tools]
        F5[Build binary .deb packages for distros]
        F6[Extract tag and version]
        F7[Create GitHub release and upload artifacts]
    end

    D10 --> F1
    E13 --> F1
    F1 --> F2 --> F3 --> F4 --> F5 --> F6 --> F7

    %% Build Homebrew Formula Job
    subgraph Build Homebrew Formula
        G1[Checkout code]
        G2[Download package artifacts]
        G3[Extract version from tag]
        G4[Compute SHA256 of source tarball]
        G5[Generate formula files]
        G6[Upload updated tap directory]
    end

    F7 --> G1
    G1 --> G2 --> G3 --> G4 --> G5 --> G6

    %% Publish PPA Job
    subgraph Publish PPA
        H1[Checkout code]
        H2[Download Debian artifacts]
        H3[Set up GPG and dput config]
        H4[Install upload tools]
        H5[Publish to PPA]
    end

    G6 --> H1
    H1 --> H2 --> H3 --> H4 --> H5

    %% Publish PyPI Job
    subgraph Publish PyPI
        I1[Checkout code]
        I2[Download Python package artifacts]
        I3[Publish to PyPI]
    end

    G6 --> I1
    I1 --> I2 --> I3

    %% Publish Test PyPI Job
    subgraph Publish Test PyPI
        J1[Checkout code]
        J2[Download Python package artifacts]
        J3[Publish to Test PyPI]
    end

    G6 --> J1
    J1 --> J2 --> J3

    %% Publish Homebrew Formula Job
    subgraph Publish Homebrew Formula
        K1[Checkout current repo]
        K2[Download formula artifact]
        K3[Clone Homebrew tap repo]
        K4[Copy new formula into tap repo]
        K5[Commit and push formula updates]
    end

    H5 --> K1
    I3 --> K1
    J3 --> K1
    G6 --> K1
    K1 --> K2 --> K3 --> K4 --> K5
